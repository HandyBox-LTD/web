# No spaces around `=` — values are trimmed in codegen, but stray spaces break many tools.
SCHEMA_ACCESS_TOKEN=""
NEXT_PUBLIC_GRAPHQL_URL=""
# NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000

# Optional: full schema SDL URL for codegen (overrides NEXT_PUBLIC_GRAPHQL_URL + /schema).
# Use on Vercel if the public API host differs or NEXT_PUBLIC_GRAPHQL_URL is unset at build time.
GRAPHQL_SCHEMA_URL=""

# Optional: local SDL path for codegen when the remote schema URL is unreachable (e.g. CI).
GRAPHQL_SCHEMA_FILE=""

NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""
